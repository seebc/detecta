{
  "functions": {
    "*.php": {
      "runtime": "vercel-php@0.6.2"
    }
  },
  "routes": [
    { "src": "/", "dest": "/index.php" },
    { "src": "/captura", "dest": "/captura.php" },
    { "src": "/historial", "dest": "/historial.php" },
    { "src": "/(.*\\.html)", "dest": "/$1" },
    { "src": "/style.css", "dest": "/style.css" }
  ]
}
