{
  "builds": [
    {
      "src": "*.php",
      "use": "vercel-php@0.6.2"
    }
  ],
  "routes": [
    { "src": "/", "dest": "/index.php" },
    { "src": "/captura", "dest": "/captura.php" },
    { "src": "/historial", "dest": "/historial.php" },
    { "src": "/(.*\\.html)", "dest": "/$1" },
    { "src": "/(.*\\.css)", "dest": "/$1" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}
